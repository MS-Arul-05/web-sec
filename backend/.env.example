# ---- Server ----
NODE_ENV=development
PORT=4000
# Comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:3000

# ---- Supabase Auth ----
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_JWKS_URL=https://YOUR-PROJECT.supabase.co/auth/v1/.well-known/jwks.json
# Secret (service) key — server-side ONLY, never expose to the frontend.
# Required only for admin operations; token verification uses the JWKS above.
SUPABASE_SECRET_KEY=

# ---- Database (Supabase Postgres) ----
# Supabase → Connect → ORMs/Prisma. Session pooler (port 5432) works for
# `prisma db push` and a long-running server. For serverless (Vercel), use the
# transaction pooler (6543) with ?pgbouncer=true instead.
DATABASE_URL="postgresql://postgres.YOUR-PROJECT:YOUR-DB-PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# ---- Scanner engine ----
SCAN_TIMEOUT_MS=8000
# Optional: Google Safe Browsing API key enables real malware/blacklist checks
GOOGLE_SAFE_BROWSING_KEY=

# ---- Gemini AI threat analysis (optional; server-side only) ----
# Google AI Studio API key. When set, scans include AI-identified threats.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
