# ---- Server ----
NODE_ENV=development
PORT=4000
# Comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:3000

# ---- Auth ----
# Generate a strong secret: `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# ---- Database ----
# SQLite (default, zero-config). For PostgreSQL use:
# DATABASE_URL="postgresql://user:pass@localhost:5432/secureweb?schema=public"
DATABASE_URL="file:./dev.db"

# ---- Scanner engine ----
SCAN_TIMEOUT_MS=8000
# Optional: Google Safe Browsing API key enables real malware/blacklist checks
GOOGLE_SAFE_BROWSING_KEY=
